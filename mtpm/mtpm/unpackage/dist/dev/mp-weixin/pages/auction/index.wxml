<view class="p-10"><scroll-view style="height:100vh;" lower-threshold="{{50}}" scroll-y="true" data-event-opts="{{[['scrolltolower',[['loadMore',['$event']]]]]}}" bindscrolltolower="__e"><block wx:for="{{productlist}}" wx:for-item="item" wx:for-index="__i0__"><view data-event-opts="{{[['tap',[['toSpecial',['$0','$1'],[[['productlist','',__i0__,'id']],[['productlist','',__i0__,'cate_id']]]]]]]}}" style="margin-top:10px;" bindtap="__e"><view class="flex"><view style="{{'width:30%;'+('height:'+imageH+'px')}}"><image class="w-full h-full cover radius-10" src="{{item.image}}" mode="aspectFill"></image></view><view style="width:66%;padding:8px 0;"><view class="bold">{{item.store_name}}</view><view class="lineH-30 font-14 pt-5">结拍价：<text style="color:#a71f24;">{{item.price}}</text></view><view class="lineH-30 font-14">{{"结拍时间："+item.presale_end_time}}</view></view></view></view></block><block wx:if="{{loading==1}}"><view class="loading-text">加载中...</view></block><block wx:if="{{loading==2}}"><view class="loading-text">没有更多数据了</view></block></scroll-view></view>
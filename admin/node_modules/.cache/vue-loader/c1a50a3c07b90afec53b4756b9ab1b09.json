{"remainingRequest":"C:\\Users\\25038\\Desktop\\CRMEB-BZ v5.6.3(20250721)\\template\\admin\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!C:\\Users\\25038\\Desktop\\CRMEB-BZ v5.6.3(20250721)\\template\\admin\\src\\pages\\kefu\\pc\\components\\order_detail.vue?vue&type=style&index=0&id=0a604f71&lang=scss&scoped=true","dependencies":[{"path":"C:\\Users\\25038\\Desktop\\CRMEB-BZ v5.6.3(20250721)\\template\\admin\\src\\pages\\kefu\\pc\\components\\order_detail.vue","mtime":1757906223212},{"path":"C:\\Users\\25038\\Desktop\\CRMEB-BZ v5.6.3(20250721)\\template\\admin\\node_modules\\css-loader\\index.js","mtime":1757912262822},{"path":"C:\\Users\\25038\\Desktop\\CRMEB-BZ v5.6.3(20250721)\\template\\admin\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1757912277137},{"path":"C:\\Users\\25038\\Desktop\\CRMEB-BZ v5.6.3(20250721)\\template\\admin\\node_modules\\postcss-loader\\src\\index.js","mtime":1757912268700},{"path":"C:\\Users\\25038\\Desktop\\CRMEB-BZ v5.6.3(20250721)\\template\\admin\\node_modules\\sass-loader\\dist\\cjs.js","mtime":1757912261430},{"path":"C:\\Users\\25038\\Desktop\\CRMEB-BZ v5.6.3(20250721)\\template\\admin\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1757912261491},{"path":"C:\\Users\\25038\\Desktop\\CRMEB-BZ v5.6.3(20250721)\\template\\admin\\node_modules\\vue-loader\\lib\\index.js","mtime":1757912272492}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["order_detail.vue"],"names":[],"mappings":";AAmHA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"order_detail.vue","sourceRoot":"src/pages/kefu/pc/components","sourcesContent":["<template>\n  <div class=\"order_detail\" v-if=\"orderDetail.userInfo\">\n    <div class=\"msg-box\">\n      <div class=\"box-title\">收货信息</div>\n      <div class=\"msg-wrapper\">\n        <div class=\"msg-item\">\n          <div class=\"item\"><span>用户昵称：</span>{{ orderDetail.userInfo.nickname }}</div>\n          <div class=\"item\"><span>收货人：</span>{{ orderDetail.orderInfo.real_name }}</div>\n        </div>\n        <div class=\"msg-item\">\n          <div class=\"item\"><span>联系电话：</span>{{ orderDetail.orderInfo.user_phone }}</div>\n          <div class=\"item\"><span>收货地址：</span>{{ orderDetail.orderInfo.user_address }}</div>\n        </div>\n      </div>\n    </div>\n    <div class=\"msg-box\" style=\"border: none\">\n      <div class=\"box-title\">订单信息</div>\n      <div class=\"msg-wrapper\">\n        <div class=\"msg-item\">\n          <div class=\"item\"><span>订单ID：</span>{{ orderDetail.orderInfo.order_id }}</div>\n          <div class=\"item\" style=\"color: red\">\n            <span style=\"color: red\">订单状态：</span>{{ orderDetail.orderInfo._status._title }}\n          </div>\n        </div>\n        <div class=\"msg-item\">\n          <div class=\"item\"><span>商品总数：</span>{{ orderDetail.orderInfo.total_num }}</div>\n          <div class=\"item\">\n            <span>商品总价：</span\n            >{{ parseFloat(orderDetail.orderInfo.total_price) + parseFloat(orderDetail.orderInfo.vip_true_price || 0) }}\n          </div>\n        </div>\n        <div class=\"msg-item\">\n          <div class=\"item\"><span>交付邮费：</span>{{ orderDetail.orderInfo.pay_postage }}</div>\n          <div class=\"item\"><span>优惠券金额：</span>{{ orderDetail.orderInfo.coupon_price }}</div>\n        </div>\n        <div class=\"msg-item\">\n          <div class=\"item\"><span>实际支付：</span>{{ orderDetail.orderInfo.pay_price }}</div>\n          <div class=\"item\"><span>创建时间：</span>{{ orderDetail.orderInfo.add_time }}</div>\n        </div>\n        <div class=\"msg-item\">\n          <div class=\"item\"><span>支付方式：</span>{{ orderDetail.orderInfo._status._payType }}</div>\n          <div class=\"item\"><span>推广人：</span>{{ orderDetail.userInfo.spread_name }}</div>\n        </div>\n        <div class=\"msg-item\">\n          <div class=\"item\"><span>商家备注：</span>{{ orderDetail.orderInfo.remark }}</div>\n        </div>\n      </div>\n    </div>\n    <div class=\"goods-box\">\n      <el-table :data=\"orderList\">\n        <el-table-column label=\"商品ID\" width=\"80\">\n          <template slot-scope=\"scope\">\n            <span>{{ scope.row.productInfo.id }}</span>\n          </template>\n        </el-table-column>\n        <el-table-column label=\"商品名称\" min-width=\"130\">\n          <template slot-scope=\"scope\">\n            <div class=\"product_info\">\n              <img :src=\"scope.row.productInfo.image\" alt=\"\" />\n              <p>{{ scope.row.productInfo.store_name }}</p>\n            </div>\n          </template>\n        </el-table-column>\n        <el-table-column label=\"商品分类\" min-width=\"130\">\n          <template slot-scope=\"scope\">\n            <span>{{ scope.row.class_name }}</span>\n          </template>\n        </el-table-column>\n        <el-table-column label=\"商品售价\" min-width=\"130\">\n          <template slot-scope=\"scope\">\n            <span>{{ scope.row.productInfo.attrInfo.price }}</span>\n          </template>\n        </el-table-column>\n        <el-table-column label=\"商品数量\" min-width=\"130\">\n          <template slot-scope=\"scope\">\n            <span>{{ scope.row.cart_num }}</span>\n          </template>\n        </el-table-column>\n      </el-table>\n    </div>\n  </div>\n</template>\n\n<script>\nimport { orderInfo } from '@/api/kefu';\nexport default {\n  name: 'order_detail',\n  props: {\n    orderId: {\n      type: String | Number,\n      default: '',\n    },\n  },\n  data() {\n    return {\n      orderDetail: {},\n      orderList: [],\n    };\n  },\n  mounted() {\n    this.getOrderInfo();\n  },\n  methods: {\n    getOrderInfo() {\n      orderInfo(this.orderId).then((res) => {\n        res.data.orderInfo.add_time = this.$moment(parseInt(res.data.orderInfo.add_time) * 1000).format('YYYY-MM-DD');\n        this.orderDetail = res.data;\n        this.orderList = res.data.orderInfo.cartInfo;\n      });\n    },\n  },\n};\n</script>\n\n<style lang=\"scss\" scoped>\n.order_detail {\n  .msg-box {\n    border-bottom: 1px solid #e8eaed;\n    .box-title {\n      padding-top: 20px;\n      font-size: 16px;\n      color: #333;\n    }\n    .msg-wrapper {\n      margin-top: 15px;\n      padding-bottom: 10px;\n      .msg-item {\n        display: flex;\n        .item {\n          flex: 1;\n          margin-bottom: 15px;\n          color: #606266;\n          font-size: 13px;\n          span {\n            font-size: 13px;\n            font-weight: 400;\n            color: #909399;\n          }\n        }\n      }\n    }\n    &:first-child .box-title {\n      padding-top: 0;\n    }\n  }\n  .product_info {\n    display: flex;\n    align-items: center;\n    img {\n      width: 36px;\n      height: 36px;\n      border-radius: 4px;\n      margin-right: 10px;\n    }\n  }\n}\n</style>\n"]}]}
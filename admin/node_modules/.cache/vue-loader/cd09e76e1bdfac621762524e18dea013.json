{"remainingRequest":"/Users/shijie/mac/vscode/company/shi-boss/admin/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/shijie/mac/vscode/company/shi-boss/admin/src/pages/product/productAdd/components/BasicInfo.vue?vue&type=script&lang=js","dependencies":[{"path":"/Users/shijie/mac/vscode/company/shi-boss/admin/src/pages/product/productAdd/components/BasicInfo.vue","mtime":1761283273000},{"path":"/Users/shijie/mac/vscode/company/shi-boss/admin/node_modules/cache-loader/dist/cjs.js","mtime":1757912261000},{"path":"/Users/shijie/mac/vscode/company/shi-boss/admin/node_modules/babel-loader/lib/index.js","mtime":1757912272000},{"path":"/Users/shijie/mac/vscode/company/shi-boss/admin/node_modules/cache-loader/dist/cjs.js","mtime":1757912261000},{"path":"/Users/shijie/mac/vscode/company/shi-boss/admin/node_modules/vue-loader/lib/index.js","mtime":1757912272000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["BasicInfo.vue"],"names":[],"mappings":";AAmGA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"BasicInfo.vue","sourceRoot":"src/pages/product/productAdd/components","sourcesContent":["<template>\r\n\t<!-- 基础信息 -->\r\n\t<el-row :gutter=\"24\">\r\n\t\t<el-col :span=\"24\">\r\n\t\t\t<el-form-item label=\"商品类型：\" props=\"is_virtual\">\r\n\t\t\t\t<div class=\"virtual\" :class=\"formValidate.virtual_type == item.id ? 'virtual_boder' : 'virtual_boder2'\"\r\n\t\t\t\t\tv-for=\"(item, index) in goodsType\" :key=\"index\" v-db-click @click=\"virtualbtn(item.id, 2)\" v-show=\"\r\n            (formValidate.id && formValidate.virtual_type == item.id) ||\r\n            (isCai == -1 && index == 0 && !formValidate.id) ||\r\n            (isCai == 0 && !formValidate.id)\r\n          \">\r\n\t\t\t\t\t<div class=\"virtual_top\">{{ item.tit }}</div>\r\n\t\t\t\t\t<div class=\"virtual_bottom\">({{ item.tit2 }})</div>\r\n\t\t\t\t\t<div v-if=\"formValidate.virtual_type == item.id\" class=\"virtual_san\"></div>\r\n\t\t\t\t\t<div v-if=\"formValidate.virtual_type == item.id\" class=\"virtual_dui\">✓</div>\r\n\t\t\t\t</div>\r\n\t\t\t</el-form-item>\r\n\t\t</el-col>\r\n\r\n\t\t<el-col :span=\"24\">\r\n\t\t\t<el-form-item label=\"商品名称：\" prop=\"store_name\">\r\n\t\t\t\t<el-input class=\"content_width\" v-model=\"formValidate.store_name\" placeholder=\"请输入商品名称\" maxlength=\"80\"\r\n\t\t\t\t\tshow-word-limit />\r\n\t\t\t</el-form-item>\r\n\t\t</el-col>\r\n\r\n\t\t<el-col :span=\"24\">\r\n\t\t\t<el-form-item label=\"单位：\" prop=\"unit_name\">\r\n\t\t\t\t<el-input class=\"input_width\" v-model=\"formValidate.unit_name\" placeholder=\"请输入单位\" maxlength=\"5\"\r\n\t\t\t\t\tshow-word-limit />\r\n\t\t\t</el-form-item>\r\n\t\t</el-col>\r\n\t\t<el-col :span=\"24\">\r\n\t\t\t<el-form-item label=\"商品轮播图：\" prop=\"slider_image\">\r\n\t\t\t\t<div class=\"acea-row\">\r\n\t\t\t\t\t<div class=\"pictrue\" v-for=\"(item, index) in formValidate.slider_image\" :key=\"index\"\r\n\t\t\t\t\t\tdraggable=\"true\" @dragstart=\"handleDragStart($event, item)\"\r\n\t\t\t\t\t\t@dragover.prevent=\"handleDragOver($event, item)\" @dragenter=\"handleDragEnter($event, item)\"\r\n\t\t\t\t\t\t@dragend=\"handleDragEnd($event, item)\">\r\n\t\t\t\t\t\t<img v-lazy=\"item\" />\r\n\t\t\t\t\t\t<i class=\"el-icon-error btndel\" v-db-click @click=\"handleRemove(index)\"></i>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t\t<div v-if=\"formValidate.slider_image.length < 10\" class=\"upLoad acea-row row-center-wrapper\"\r\n\t\t\t\t\t\tv-db-click @click=\"modalPicTap('duo')\">\r\n\t\t\t\t\t\t<i class=\"el-icon-picture-outline\" style=\"font-size: 24px\"></i>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t\t<el-input v-model=\"formValidate.slider_image[0]\" style=\"display: none\"></el-input>\r\n\t\t\t\t</div>\r\n\r\n\t\t\t\t<div class=\"tips-info\">建议尺寸：800*800，可拖拽改变图片顺序，默认首张图为主图，最多上传10张</div>\r\n\r\n\t\t\t\t<!-- <div class=\"tips\">(最多10张<br />750*750)</div> -->\r\n\t\t\t</el-form-item>\r\n\t\t</el-col>\r\n\t\t<el-col :span=\"24\" id=\"selectvideo\">\r\n\t\t\t<el-form-item label=\"添加视频：\" prop=\"video_link\">\r\n\t\t\t\t<div v-if=\"!formValidate.video_link\" class=\"videbox\" @click=\"addVideo\">\r\n\t\t\t\t\t<i class=\"el-icon-video-camera\"></i>\r\n\t\t\t\t</div>\r\n\t\t\t\t<div class=\"box-video-style\" v-if=\"formValidate.video_link\">\r\n\t\t\t\t\t<video style=\"width: 100%; height: 100%\" :src=\"formValidate.video_link\" controls=\"controls\">\r\n\t\t\t\t\t\t您的浏览器不支持 video 标签。\r\n\t\t\t\t\t</video>\r\n\t\t\t\t\t<div class=\"mark\"></div>\r\n\t\t\t\t\t<i class=\"el-icon-delete iconv\" v-db-click @click=\"delVideo\"></i>\r\n\t\t\t\t</div>\r\n\t\t\t\t<Progress class=\"progress\" :percent=\"progress\" :stroke-width=\"5\" v-if=\"upload.videoIng\" />\r\n\t\t\t\t<div class=\"tips-info\">建议时长：9～30秒，视频宽高比16:9</div>\r\n\t\t\t</el-form-item>\r\n\t\t</el-col>\r\n\t\t<el-col :span=\"24\">\r\n\t\t\t<el-form-item label=\"商品分类：\" prop=\"cate_id\">\r\n\t\t\t\t<el-cascader class=\"content_width\" v-model=\"formValidate.cate_id\" filterable size=\"small\"\r\n\t\t\t\t\t:options=\"treeSelect\" :props=\"{ multiple: true, checkStrictly: true, emitPath: false }\"\r\n\t\t\t\t\tclearable></el-cascader>\r\n\t\t\t\t<span class=\"addfont\" v-db-click @click=\"addCate\">新增分类</span>\r\n\t\t\t</el-form-item>\r\n\t\t</el-col>\r\n\t\t<el-col :span=\"24\">\r\n\t\t\t<el-form-item label=\"商品标签：\">\r\n\t\t\t\t<div class=\"flex\">\r\n\t\t\t\t\t<useLabel v-if=\"tileLabelList.length\" :activeId.sync=\"formValidate.label_list\"\r\n\t\t\t\t\t\t:listData=\"tileLabelList\"></useLabel>\r\n\t\t\t\t\t<el-button v-db-click @click=\"addGoodsTag\">选择标签</el-button>\r\n\t\t\t\t</div>\r\n\t\t\t</el-form-item>\r\n\t\t</el-col>\r\n\t\t<el-col :span=\"24\">\r\n\t\t\t<el-form-item label=\"商品状态：\">\r\n\t\t\t\t<el-radio-group v-model=\"formValidate.is_show\">\r\n\t\t\t\t\t<el-radio :label=\"1\" class=\"radio\">上架</el-radio>\r\n\t\t\t\t\t<el-radio :label=\"0\">下架</el-radio>\r\n\t\t\t\t</el-radio-group>\r\n\t\t\t</el-form-item>\r\n\t\t</el-col>\r\n\t</el-row>\r\n</template>\r\n\r\n<script>\r\n\timport useLabel from '@/components/goodsLabel/useLabel';\r\n\r\n\texport default {\r\n\t\tname: 'BasicInfo',\r\n\t\tcomponents: {\r\n\t\t\tuseLabel,\r\n\t\t},\r\n\t\tprops: {\r\n\t\t\tformValidate: {\r\n\t\t\t\ttype: Object,\r\n\t\t\t\trequired: true,\r\n\t\t\t},\r\n\t\t\tgoodsType: {\r\n\t\t\t\ttype: Array,\r\n\t\t\t\trequired: true,\r\n\t\t\t},\r\n\t\t\ttreeSelect: {\r\n\t\t\t\ttype: Array,\r\n\t\t\t\trequired: true,\r\n\t\t\t},\r\n\t\t\ttileLabelList: {\r\n\t\t\t\ttype: Array,\r\n\t\t\t\trequired: true,\r\n\t\t\t},\r\n\t\t\tupload: {\r\n\t\t\t\ttype: Object,\r\n\t\t\t\trequired: true,\r\n\t\t\t},\r\n\t\t\tisCai: {\r\n\t\t\t\ttype: Number | String,\r\n\t\t\t\trequired: true,\r\n\t\t\t},\r\n\t\t},\r\n\t\tmethods: {\r\n\t\t\tvirtualbtn(id, type) {\r\n\t\t\t\tthis.$emit('virtualbtn', id, type);\r\n\t\t\t},\r\n\t\t\thandleDragStart(e, item) {\r\n\t\t\t\tthis.$emit('handleDragStart', e, item);\r\n\t\t\t},\r\n\t\t\thandleDragOver(e, item) {\r\n\t\t\t\tthis.$emit('handleDragOver', e, item);\r\n\t\t\t},\r\n\t\t\thandleDragEnter(e, item) {\r\n\t\t\t\tthis.$emit('handleDragEnter', e, item);\r\n\t\t\t},\r\n\t\t\thandleDragEnd(e, item) {\r\n\t\t\t\tthis.$emit('handleDragEnd', e, item);\r\n\t\t\t},\r\n\t\t\thandleRemove(index) {\r\n\t\t\t\tthis.$emit('handleRemove', index);\r\n\t\t\t},\r\n\t\t\tmodalPicTap(type) {\r\n\t\t\t\tthis.$emit('modalPicTap', type);\r\n\t\t\t},\r\n\t\t\taddVideo() {\r\n\t\t\t\tthis.$emit('addVideo');\r\n\t\t\t},\r\n\t\t\tdelVideo() {\r\n\t\t\t\tthis.$emit('delVideo');\r\n\t\t\t},\r\n\t\t\taddCate() {\r\n\t\t\t\tthis.$emit('addCate');\r\n\t\t\t},\r\n\t\t\taddGoodsTag() {\r\n\t\t\t\tthis.$emit('addGoodsTag');\r\n\t\t\t},\r\n\t\t},\r\n\t};\r\n</script>\r\n<style lang=\"scss\" scoped>\r\n\t@use '../productAdd.scss' as *;\r\n</style>"]}]}
{"remainingRequest":"/Users/shijie/mac/vscode/company/shi-boss/admin/node_modules/babel-loader/lib/index.js!/Users/shijie/mac/vscode/company/shi-boss/admin/node_modules/cache-loader/dist/cjs.js??ref--0-0!/Users/shijie/mac/vscode/company/shi-boss/admin/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/shijie/mac/vscode/company/shi-boss/admin/src/pages/product/auction_session/index.vue?vue&type=script&lang=js","dependencies":[{"path":"/Users/shijie/mac/vscode/company/shi-boss/admin/src/pages/product/auction_session/index.vue","mtime":1780148966697},{"path":"/Users/shijie/mac/vscode/company/shi-boss/admin/babel.config.js","mtime":1757906219000},{"path":"/Users/shijie/mac/vscode/company/shi-boss/admin/.babelrc","mtime":1757906219000},{"path":"/Users/shijie/mac/vscode/company/shi-boss/admin/node_modules/cache-loader/dist/cjs.js","mtime":1757912261000},{"path":"/Users/shijie/mac/vscode/company/shi-boss/admin/node_modules/babel-loader/lib/index.js","mtime":1757912272000},{"path":"/Users/shijie/mac/vscode/company/shi-boss/admin/node_modules/cache-loader/dist/cjs.js","mtime":1757912261000},{"path":"/Users/shijie/mac/vscode/company/shi-boss/admin/node_modules/vue-loader/lib/index.js","mtime":1757912272000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["getAuctionSessionListApi","getTimedCategoryOptionsApi","createAuctionSessionApi","updateAuctionSessionApi","deleteAuctionSessionApi","bindAuctionSessionApi","name","data","loading","tableData","formVisible","formMode","formSaving","editingId","formData","formRules","required","message","trigger","bindVisible","bindSaving","currentSession","bindForm","cate_a_id","cate_b_id","bindOptionPool","bindOptionPoolLoading","bindSelectOptions","computed","optionsForA","b","Number","filter","item","id","optionsForB","a","mounted","loadList","loadBindOptionPool","methods","_this","then","res","catch","finally","_this2","force","arguments","length","undefined","Promise","resolve","Array","isArray","err","$message","error","msg","buildBindSelectOptions","row","excludeIds","Set","forEach","session","n","add","options","has","seen","map","appendCurrent","unshift","cate_name","replace","trim","concat","status_text","is_show_text","cate_a_name","cate_b_name","resetFormData","openCreate","_this3","$nextTick","$refs","formRef","clearValidate","openEdit","_this4","submitForm","_this5","validate","valid","payload","request","success","handleDelete","_this6","$confirm","confirmButtonText","cancelButtonText","type","openBind","_this7","cate_ids","showBindDialog","optionLabel","parts","push","join","submitBind","_this8","cateA","cateB","warning","session_id"],"sources":["src/pages/product/auction_session/index.vue"],"sourcesContent":["<template>\n  <div class=\"divBox\">\n    <el-card :bordered=\"false\" shadow=\"never\" class=\"ivu-mt\">\n      <div slot=\"header\" class=\"clearfix\">\n        <span>限时拍拍卖周期</span>\n      </div>\n      <div class=\"tips mb16\">\n        一个拍卖周期须<strong>同时绑定两个不同的限时拍专场</strong>（均需已开启「展示」），两场<strong>共用号牌</strong>。\n        <strong>未纳入周期的限时拍专场</strong>仍可按单场正常办牌。已绑定其它周期的专场不可再选；两场均结拍后系统自动解除绑定。\n      </div>\n      <el-button type=\"primary\" class=\"mb16\" v-db-click @click=\"openCreate\">新建周期</el-button>\n      <el-table v-loading=\"loading\" :data=\"tableData\" border stripe>\n        <el-table-column prop=\"id\" label=\"ID\" width=\"70\" />\n        <el-table-column prop=\"name\" label=\"周期名称\" min-width=\"200\" />\n        <el-table-column label=\"专场A\" min-width=\"160\">\n          <template slot-scope=\"{ row }\">\n            <span v-if=\"row.cate_a_name\">{{ row.cate_a_name }}</span>\n            <span v-else class=\"text-muted\">未绑定</span>\n          </template>\n        </el-table-column>\n        <el-table-column label=\"专场B\" min-width=\"160\">\n          <template slot-scope=\"{ row }\">\n            <span v-if=\"row.cate_b_name\">{{ row.cate_b_name }}</span>\n            <span v-else class=\"text-muted\">未绑定</span>\n          </template>\n        </el-table-column>\n        <el-table-column label=\"操作\" width=\"200\" fixed=\"right\">\n          <template slot-scope=\"{ row }\">\n            <a v-db-click @click=\"openEdit(row)\">编辑</a>\n            <el-divider direction=\"vertical\"></el-divider>\n            <a v-db-click @click=\"openBind(row)\">绑定专场</a>\n            <el-divider direction=\"vertical\"></el-divider>\n            <a v-db-click @click=\"handleDelete(row)\" class=\"text-danger\">删除</a>\n          </template>\n        </el-table-column>\n      </el-table>\n    </el-card>\n\n    <el-dialog\n      :title=\"formMode === 'edit' ? '编辑拍卖周期' : '新建拍卖周期'\"\n      :visible.sync=\"formVisible\"\n      width=\"480px\"\n      :close-on-click-modal=\"false\"\n    >\n      <el-form ref=\"formRef\" :model=\"formData\" :rules=\"formRules\" label-width=\"100px\">\n        <el-form-item label=\"周期名称\" prop=\"name\">\n          <el-input v-model=\"formData.name\" placeholder=\"如：5月双场限时拍\" maxlength=\"64\" />\n        </el-form-item>\n      </el-form>\n      <span slot=\"footer\">\n        <el-button @click=\"formVisible = false\">取消</el-button>\n        <el-button type=\"primary\" :loading=\"formSaving\" v-db-click @click=\"submitForm\">确定</el-button>\n      </span>\n    </el-dialog>\n\n    <el-dialog\n      :title=\"'绑定限时拍专场 · 周期#' + (currentSession.id || '')\"\n      :visible.sync=\"bindVisible\"\n      width=\"640px\"\n      :close-on-click-modal=\"false\"\n    >\n      <div class=\"tips mb12\">\n        须选择<strong>两个不同</strong>的限时拍专场，且均为「展示」状态；已绑定其它周期的专场不会出现在列表中。\n      </div>\n      <el-alert\n        v-if=\"bindVisible && !bindOptionPoolLoading && bindSelectOptions.length === 0\"\n        type=\"warning\"\n        :closable=\"false\"\n        class=\"mb12\"\n        title=\"当前没有可选的限时拍专场\"\n        description=\"请先在「拍卖专场」中创建限时拍并开启展示，并确认未被其它周期占用。\"\n      />\n      <el-form label-width=\"80px\" v-loading=\"bindOptionPoolLoading\">\n        <el-form-item label=\"专场A\" required>\n          <el-select\n            v-model=\"bindForm.cate_a_id\"\n            filterable\n            clearable\n            placeholder=\"选择专场A\"\n            style=\"width: 100%\"\n          >\n            <el-option\n              v-for=\"item in optionsForA\"\n              :key=\"'a-' + item.id\"\n              :label=\"optionLabel(item)\"\n              :value=\"item.id\"\n            />\n          </el-select>\n        </el-form-item>\n        <el-form-item label=\"专场B\" required>\n          <el-select\n            v-model=\"bindForm.cate_b_id\"\n            filterable\n            clearable\n            placeholder=\"选择专场B\"\n            style=\"width: 100%\"\n          >\n            <el-option\n              v-for=\"item in optionsForB\"\n              :key=\"'b-' + item.id\"\n              :label=\"optionLabel(item)\"\n              :value=\"item.id\"\n            />\n          </el-select>\n        </el-form-item>\n      </el-form>\n      <span slot=\"footer\">\n        <el-button @click=\"bindVisible = false\">取消</el-button>\n        <el-button type=\"primary\" :loading=\"bindSaving\" v-db-click @click=\"submitBind\">保存绑定</el-button>\n      </span>\n    </el-dialog>\n  </div>\n</template>\n\n<script>\nimport {\n  getAuctionSessionListApi,\n  getTimedCategoryOptionsApi,\n  createAuctionSessionApi,\n  updateAuctionSessionApi,\n  deleteAuctionSessionApi,\n  bindAuctionSessionApi,\n} from '@/api/auctionSession';\n\nexport default {\n  name: 'AuctionSessionConfig',\n  data() {\n    return {\n      loading: false,\n      tableData: [],\n      formVisible: false,\n      formMode: 'create',\n      formSaving: false,\n      editingId: 0,\n      formData: {\n        name: '',\n      },\n      formRules: {\n        name: [{ required: true, message: '请输入周期名称', trigger: 'blur' }],\n      },\n      bindVisible: false,\n      bindSaving: false,\n      currentSession: {},\n      bindForm: {\n        cate_a_id: null,\n        cate_b_id: null,\n      },\n      bindOptionPool: [],\n      bindOptionPoolLoading: false,\n      bindSelectOptions: [],\n    };\n  },\n  computed: {\n    optionsForA() {\n      const b = Number(this.bindForm.cate_b_id) || 0;\n      return this.bindSelectOptions.filter((item) => Number(item.id) !== b);\n    },\n    optionsForB() {\n      const a = Number(this.bindForm.cate_a_id) || 0;\n      return this.bindSelectOptions.filter((item) => Number(item.id) !== a);\n    },\n  },\n  mounted() {\n    this.loadList();\n    this.loadBindOptionPool();\n  },\n  methods: {\n    loadList() {\n      this.loading = true;\n      getAuctionSessionListApi()\n        .then((res) => {\n          this.tableData = res.data || [];\n        })\n        .catch(() => {\n          this.tableData = [];\n        })\n        .finally(() => {\n          this.loading = false;\n        });\n    },\n    /** 进入页面只请求一次：可绑定专场池（session_id=0，不含已被任意周期占用的） */\n    loadBindOptionPool(force = false) {\n      if (this.bindOptionPoolLoading) {\n        return Promise.resolve();\n      }\n      if (!force && this.bindOptionPool.length) {\n        return Promise.resolve();\n      }\n      this.bindOptionPoolLoading = true;\n      return getTimedCategoryOptionsApi(0)\n        .then((res) => {\n          this.bindOptionPool = Array.isArray(res.data) ? res.data : [];\n        })\n        .catch((err) => {\n          this.bindOptionPool = [];\n          this.$message.error(err.msg || '加载限时拍专场列表失败，请检查权限或稍后重试');\n        })\n        .finally(() => {\n          this.bindOptionPoolLoading = false;\n        });\n    },\n    /** 打开绑定弹窗：本地合并当前周期已绑专场，不再请求接口 */\n    buildBindSelectOptions(row) {\n      const excludeIds = new Set();\n      (this.tableData || []).forEach((session) => {\n        if (Number(session.id) === Number(row.id)) {\n          return;\n        }\n        [session.cate_a_id, session.cate_b_id].forEach((id) => {\n          const n = Number(id) || 0;\n          if (n > 0) {\n            excludeIds.add(n);\n          }\n        });\n      });\n      const options = (this.bindOptionPool || []).filter((item) => {\n        const id = Number(item.id) || 0;\n        return id > 0 && !excludeIds.has(id);\n      });\n      const seen = new Set(options.map((item) => Number(item.id)));\n      const appendCurrent = (id, name) => {\n        const n = Number(id) || 0;\n        if (n <= 0 || seen.has(n)) {\n          return;\n        }\n        seen.add(n);\n        options.unshift({\n          id: n,\n          cate_name: (name || '').replace(/\\(#\\d+\\)$/, '').trim() || `专场#${n}`,\n          status_text: '',\n          is_show_text: '已绑定本周期',\n        });\n      };\n      appendCurrent(row.cate_a_id, row.cate_a_name);\n      appendCurrent(row.cate_b_id, row.cate_b_name);\n      return options;\n    },\n    resetFormData() {\n      this.formData = { name: '' };\n      this.editingId = 0;\n    },\n    openCreate() {\n      this.formMode = 'create';\n      this.resetFormData();\n      this.formVisible = true;\n      this.$nextTick(() => {\n        if (this.$refs.formRef) this.$refs.formRef.clearValidate();\n      });\n    },\n    openEdit(row) {\n      this.formMode = 'edit';\n      this.editingId = row.id;\n      this.formData = {\n        name: row.name || '',\n      };\n      this.formVisible = true;\n      this.$nextTick(() => {\n        if (this.$refs.formRef) this.$refs.formRef.clearValidate();\n      });\n    },\n    submitForm() {\n      this.$refs.formRef.validate((valid) => {\n        if (!valid) return;\n        this.formSaving = true;\n        const payload = { name: this.formData.name };\n        const request =\n          this.formMode === 'edit'\n            ? updateAuctionSessionApi(this.editingId, payload)\n            : createAuctionSessionApi(payload);\n        request\n          .then((res) => {\n            this.$message.success(res.msg || (this.formMode === 'edit' ? '修改成功' : '创建成功'));\n            this.formVisible = false;\n            this.loadList();\n          })\n          .finally(() => {\n            this.formSaving = false;\n          });\n      });\n    },\n    handleDelete(row) {\n      this.$confirm(`确定删除周期「${row.name}」吗？将自动解绑已关联专场。`, '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning',\n      })\n        .then(() => deleteAuctionSessionApi(row.id))\n        .then((res) => {\n          this.$message.success(res.msg || '删除成功');\n          this.loadList();\n        })\n        .catch(() => {});\n    },\n    openBind(row) {\n      this.currentSession = row;\n      this.bindForm.cate_a_id = row.cate_a_id ? Number(row.cate_a_id) : null;\n      this.bindForm.cate_b_id = row.cate_b_id ? Number(row.cate_b_id) : null;\n      if (!this.bindForm.cate_a_id && Array.isArray(row.cate_ids) && row.cate_ids[0]) {\n        this.bindForm.cate_a_id = Number(row.cate_ids[0]);\n      }\n      if (!this.bindForm.cate_b_id && Array.isArray(row.cate_ids) && row.cate_ids[1]) {\n        this.bindForm.cate_b_id = Number(row.cate_ids[1]);\n      }\n      const showBindDialog = () => {\n        this.bindSelectOptions = this.buildBindSelectOptions(row);\n        this.bindVisible = true;\n      };\n      if (this.bindOptionPoolLoading) {\n        this.loadBindOptionPool().then(showBindDialog);\n      } else {\n        showBindDialog();\n      }\n    },\n    optionLabel(item) {\n      const parts = [`#${item.id} ${item.cate_name}`];\n      if (item.status_text) parts.push(item.status_text);\n      if (item.is_show_text) parts.push(item.is_show_text);\n      return parts.join(' · ');\n    },\n    submitBind() {\n      const cateA = Number(this.bindForm.cate_a_id) || 0;\n      const cateB = Number(this.bindForm.cate_b_id) || 0;\n      if (!cateA || !cateB) {\n        this.$message.warning('请选择专场A和专场B');\n        return;\n      }\n      if (cateA === cateB) {\n        this.$message.warning('专场A与专场B不能相同');\n        return;\n      }\n      this.bindSaving = true;\n      bindAuctionSessionApi({\n        session_id: this.currentSession.id,\n  
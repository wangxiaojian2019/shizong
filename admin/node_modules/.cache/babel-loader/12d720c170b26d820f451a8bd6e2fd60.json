}\n\n/** 修改拍卖周期 */\nexport function updateAuctionSessionApi(id, data) {\n  return request({\n    url: `product/auction_session/${id}`,\n    method: 'put',\n    data,\n  });\n}\n\n/** 删除拍卖周期 */\nexport function deleteAuctionSessionApi(id) {\n  return request({\n    url: `product/auction_session/${id}`,\n    method: 'delete',\n  });\n}\n"],"mappings":"AAAA,OAAOA,OAAO,MAAM,gBAAgB;;AAEpC;AACA,OAAO,SAASC,wBAAwBA,CAAA,EAAG;EACzC,OAAOD,OAAO,CAAC;IACbE,GAAG,EAAE,yBAAyB;IAC9BC,MAAM,EAAE;EACV,CAAC,CAAC;AACJ;;AAEA;AACA,OAAO,SAASC,0BAA0BA,CAAA,EAAgB;EAAA,IAAfC,SAAS,GAAAC,SAAA,CAAAC,MAAA,QAAAD,SAAA,QAAAE,SAAA,GAAAF,SAAA,MAAG,CAAC;EACtD,OAAON,OAAO,CAAC;IACbE,GAAG,EAAE,0CAA0C;IAC/CC,MAAM,EAAE,KAAK;IACbM,MAAM,EAAE;MAAEC,UAAU,EAAEL;IAAU;EAClC,CAAC,CAAC;AACJ;;AAEA;AACA,OAAO,SAASM,uBAAuBA,CAACC,IAAI,EAAE;EAC5C,OAAOZ,OAAO,CAAC;IACbE,GAAG,EAAE,yBAAyB;IAC9BC,MAAM,EAAE,MAAM;IACdS,IAAI,EAAJA;EACF,CAAC,CAAC;AACJ;;AAEA;AACA,OAAO,SAASC,qBAAqBA,CAACD,IAAI,EAAE;EAC1C,OAAOZ,OAAO,CAAC;IACbE,GAAG,EAAE,8BAA8B;IACnCC,MAAM,EAAE,MAAM;IACdS,IAAI,EAAJA;EACF,CAAC,CAAC;AACJ;;AAEA;AACA,OAAO,SAASE,uBAAuBA,CAACC,EAAE,EAAEH,IAAI,EAAE;EAChD,OAAOZ,OAAO,CAAC;IACbE,GAAG,6BAAAc,MAAA,CAA6BD,EAAE,CAAE;IACpCZ,MAAM,EAAE,KAAK;IACbS,IAAI,EAAJA;EACF,CAAC,CAAC;AACJ;;AAEA;AACA,OAAO,SAASK,uBAAuBA,CAACF,EAAE,EAAE;EAC1C,OAAOf,OAAO,CAAC;IACbE,GAAG,6BAAAc,MAAA,CAA6BD,EAAE,CAAE;IACpCZ,MAAM,EAAE;EACV,CAAC,CAAC;AACJ","ignoreList":[]}]}